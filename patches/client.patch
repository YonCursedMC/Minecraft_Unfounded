+package net.minecraft.src;
+
+import javax.sound.sampled.AudioFormat;
+import javax.sound.sampled.AudioSystem;
+import javax.sound.sampled.SourceDataLine;
+
+public class NoiseSoundManager {
+    private static Thread soundThread = null;
+    private static volatile boolean running = false;
+    private static SourceDataLine line = null;
+    private static volatile float volume = 0.08f; // Low volume (0.0 to 1.0) to prevent annoyance
+
+    public static void setVolume(float v) {
+        volume = Math.max(0.0f, Math.min(1.0f, v));
+    }
+
+    public static void startNoise() {
+        if (soundThread != null && running) {
+            return;
+        }
+
+        running = true;
+        soundThread = new Thread(new Runnable() {
+            @Override
+            public void run() {
+                try {
+                    // 44100Hz, 16bit, Mono, Signed, Little Endian
+                    AudioFormat format = new AudioFormat(44100.0f, 16, 1, true, false);
+                    line = AudioSystem.getSourceDataLine(format);
+                    line.open(format, 8192); // Small buffer for quick stop response
+                    line.start();
+
+                    byte[] buffer = new byte[4096];
+                    double phase = 0.0;
+                    double humFrequency = 55.0; // 55Hz (A1) deep hum
+                    java.util.Random rand = new java.util.Random();
+
+                    while (running) {
+                        for (int i = 0; i < buffer.length; i += 2) {
+                            // 55Hz deep sine wave hum
+                            double angle = phase * 2.0 * Math.PI;
+                            double val = Math.sin(angle) * 0.6;
+                            
+                            // Add 110Hz harmonic for buzz texture
+                            val += Math.sin(angle * 2.0) * 0.25;
+                            
+                            // Add a soft high-frequency colored crackle noise
+                            double noise = (rand.nextDouble() * 2.0 - 1.0) * 0.08;
+                            val += noise;
+                            
+                            // Clamp value
+                            val = Math.max(-1.0, Math.min(1.0, val));
+                            
+                            // Apply volume scaling
+                            short sample = (short) (val * 32767.0 * volume);
+                            
+                            // Write 16-bit little-endian sample
+                            buffer[i] = (byte) (sample & 0xFF);
+                            buffer[i + 1] = (byte) ((sample >> 8) & 0xFF);
+                            
+                            phase += humFrequency / 44100.0;
+                            if (phase >= 1.0) {
+                                phase -= 1.0;
+                            }
+                        }
+                        
+                        // Write to the audio line
+                        int written = 0;
+                        while (written < buffer.length && running) {
+                            int result = line.write(buffer, written, buffer.length - written);
+                            if (result < 0) break;
+                            written += result;
+                        }
+                    }
+                } catch (Exception e) {
+                    System.err.println("[Unfounded Sound] Error playing noise: " + e.getMessage());
+                } finally {
+                    cleanup();
+                }
+            }
+        }, "Unfounded Ambient Audio Thread");
+        soundThread.setDaemon(true);
+        soundThread.start();
+        System.out.println("[Unfounded Sound] Constant drone noise thread started.");
+    }
+
+    public static void stopNoise() {
+        if (!running) return;
+        running = false;
+        if (soundThread != null) {
+            soundThread.interrupt();
+            soundThread = null;
+        }
+    }
+
+    private static void cleanup() {
+        if (line != null) {
+            try {
+                line.stop();
+                line.flush();
+                line.close();
+            } catch (Exception e) {}
+            line = null;
+        }
+    }
+}
