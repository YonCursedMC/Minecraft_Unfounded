+            if (source.length() > 100) {
+                System.err.println("[Unfounded Shader] Source tail: " + source.substring(source.length() - 100));
+            } else {
+                System.err.println("[Unfounded Shader] Source content: " + source);
+            }
+            GL20.glDeleteShader(shaderId);
+            return 0;
+        }
+        return shaderId;
+    }
