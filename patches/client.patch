+								}
+							}
+						});
+
+						// クリップが閉じられるまで待機（スレッド内なのでブロックしても問題なし）
+						while (clip.isOpen()) {
+							Thread.sleep(50);
+						}
+					}
+
+				} catch (UnsupportedAudioFileException | IOException | LineUnavailableException e) {
+					System.err.println("[WavPlaySound] Error playing sound: " + resourcePath);
+					e.printStackTrace();
+				} catch (InterruptedException e) {
+					Thread.currentThread().interrupt();
+				}
+			}
+		}, "WavPlaySound-" + resourcePath).start();
+	}
+
+	/**
+	 * 指定したWAVファイルを非同期（別スレッド）で無限ループ再生する。
