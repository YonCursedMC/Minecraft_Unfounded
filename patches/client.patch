+                if (is == null) {
+                    return null;
+                }
+                InputStream bufferedIn = new BufferedInputStream(is);
+                audioStream = AudioSystem.getAudioInputStream(bufferedIn);
+            }
+            Clip clip = AudioSystem.getClip();
+            clip.open(audioStream);
+            clip.loop(Clip.LOOP_CONTINUOUSLY);
+            clip.start();
+            return clip;
+        } catch (Exception e) {
+            e.printStackTrace();
+        }
+        return null;
+    }
