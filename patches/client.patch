+    private Clip playLoopSound(String path) {
+        try {
+            File file = new File(path);
+            AudioInputStream audioStream;
+            if (file.exists()) {
+                audioStream = AudioSystem.getAudioInputStream(file);
+            } else {
+                InputStream is = GuiMainMenu.class.getResourceAsStream("/" + path.replace("./", ""));
+                if (is == null) {
+                    is = GuiMainMenu.class.getResourceAsStream(path.replace("./", ""));
